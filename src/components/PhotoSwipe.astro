---
import 'photoswipe/style.css'
---

<script>
  import imagesLoaded from 'imagesloaded'
  import PhotoSwipeLightbox from 'photoswipe/lightbox'

  const lightbox = new PhotoSwipeLightbox({
    gallery: '.item .image-list-container',
    children: 'a[data-pswp-width][data-pswp-height]',
    pswpModule: () => import('photoswipe'),
    closeOnVerticalDrag: true,
    pinchToClose: true,
    bgClickAction: 'close',
    imageClickAction: 'close',
    tapAction: 'close',
  })

  lightbox.on('open' as any, () => {
    document.body.style.overflow = 'hidden'
  })

  lightbox.on('close' as any, () => {
    document.body.style.overflow = ''
  })

  lightbox.init()

  function updatePhotoSwipeDimensions(img: HTMLImageElement) {
    const link = img.closest('a[data-pswp-width][data-pswp-height]')
    if (!link) {
      return
    }

    link.setAttribute('data-pswp-width', String(img.naturalWidth || img.width))
    link.setAttribute('data-pswp-height', String(img.naturalHeight || img.height))
  }

  function observeImage(img: HTMLImageElement) {
    const placeholder = img.closest('.image-loading-placeholder')
    if (!placeholder) {
      return
    }

    const tracker = imagesLoaded(img)
    tracker.on('done', () => {
      placeholder.classList.remove('is-image-error')
      placeholder.classList.add('is-image-loaded')
      updatePhotoSwipeDimensions(img)
    })
    tracker.on('fail', () => {
      placeholder.classList.remove('is-image-loaded')
      placeholder.classList.add('is-image-error')
    })
  }

  function initImages() {
    document.querySelectorAll<HTMLImageElement>('.image-loading-placeholder img').forEach(observeImage)
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initImages)
  } else {
    initImages()
  }
</script>
